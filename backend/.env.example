# Copy to .env and fill in. Safe to commit (no real secrets).
#
# Cursor: keys under Settings → Models / API are only for Cursor’s chat & agent.
# This Node server does not read them. Use the same OpenRouter key here if you
# like (paste from openrouter.ai/keys), or set OPENROUTER_API_KEY in the shell
# before `npm start`.

OPENROUTER_API_KEY=
# Paid: openai/gpt-4o-mini. Free: openrouter/free (can 429) or a pinned :free model from openrouter.ai/collections/free-models
OPENROUTER_MODEL=openai/gpt-4o-mini
# Retries with backoff on OpenRouter 429/503 (default 3, max 6)
# OPENROUTER_RETRY_ATTEMPTS=5
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8787
OPENROUTER_APP_NAME=Word Highlighter
PORT=8787
