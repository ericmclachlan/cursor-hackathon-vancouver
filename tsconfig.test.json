{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017", "DOM"],
    "types": ["chrome", "jest", "node"],
    "module": "commonjs",
    "outDir": "./dist-test",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "allowJs": true,
    "skipLibCheck": true
  },
  "include": ["extention/**/*.ts", "tests/**/*.ts", "backend/**/*.js"],
  "exclude": ["node_modules", "dist"]
}
