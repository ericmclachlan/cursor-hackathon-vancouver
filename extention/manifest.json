{
  "manifest_version": 3,
  "name": "Word Highlighter",
  "version": "1.0.0",
  "description": "Highlights a configurable word on every page.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["trie.js", "content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["config.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
